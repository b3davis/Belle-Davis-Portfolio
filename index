<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Portfolio</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=MuseoModerno:wght@400;500;600;700;800&family=Reddit+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    :root {
      --bg: #0d2b78;
      --white: #ffffff;
      --red: #e00000;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background: var(--bg);
      display: flex;
      justify-content: center;
      overflow-x: auto;
      font-family: "MuseoModerno", sans-serif;
    }

    .frame {
      width: 1440px;
      min-height: 1024px;
      position: relative;
      padding: 82px 120px 80px;
    }

    .nav {
      position: sticky;
      top: 20px;
      z-index: 10;
      width: 500px;
      height: 70px;
      display: flex;
      align-items: center;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.25);
      background: rgba(255,255,255,0.08);
      backdrop-filter: blur(18px);
      padding: 0 40px;
      font-family: "Reddit Sans", sans-serif;
      font-size: 16px;
      font-weight: 600;
    }

    .nav ul {
      display: flex;
      justify-content: space-between;
      width: 100%;
      list-style: none;
    }

    .nav a {
      color: white;
      text-decoration: none;
      position: relative;
      padding-bottom: 6px;
      font-weight: 600;
    }

    .nav a.active::after {
      content: "";
      position: absolute;
      bottom: 0;
      left: 0;
      width: 48px;
      height: 3px;
      background: #ff1f1f;
    }

    .grid-wrap {
      margin-top: 60px;
      width: 1200px;
      position: relative;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
    }

    .card {
      height: 220px;
      border: 1px solid white;
      border-radius: 26px;
      padding: 24px;
      display: flex;
      color: white;
      transition: background-color 0.3s ease, color 0.3s ease;
    }

    .card:hover {
      background: white;
      color: var(--bg);
    }

    .card:hover .label {
      color: var(--bg);
    }

    .label {
      font-size: 20px;
      font-weight: 500;
      color: white;
      transition: color 0.3s ease;
    }

    .top-left { align-items: flex-start; }
    .middle-left { align-items: center; }
    .bottom-center { align-items: flex-end; justify-content: center; }
    .middle-center { align-items: center; justify-content: center; text-align: center; }

    .circle-shell {
      position: absolute;
      left: 820px;
      top: -120px;
      width: 420px;
      height: 420px;
      pointer-events: none;
    }

    .circle {
      width: 100%;
      height: 100%;
      background: var(--red);
      border-radius: 50%;
      position: relative;
      animation: spin 12s linear infinite;
    }

    .circle-char {
      position: absolute;
      top: 50%;
      left: 50%;
      font-family: "MuseoModerno", sans-serif;
      font-size: 64px;   /* ✅ bigger */
      font-weight: 600;  /* ✅ updated */
      color: white;
      transform-origin: center;
    }

    @keyframes spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }

    @media (max-width: 900px) {
      .frame {
        width: 100%;
        padding: 40px 20px;
      }

      .nav {
        width: 100%;
        height: auto;
        min-height: 70px;
        padding: 16px;
        border-radius: 20px;
      }

      .nav ul {
        flex-wrap: wrap;
        justify-content: center;
        gap: 12px;
      }

      .grid-wrap {
        display: flex;
        flex-direction: column;
        gap: 20px;
      }

      .circle-shell {
        position: relative;
        top: 0;
        left: 0;
        width: 260px;
        height: 260px;
        margin: 0 auto;
        order: -1;
      }

      .grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .card {
        height: 160px;
      }

      .circle-char {
        font-size: 40px;
      }
    }

    @media (max-width: 500px) {
      .grid {
        grid-template-columns: 1fr;
      }
    }

  </style>
</head>
<body>

  <div class="frame">

    <nav class="nav">
      <ul>
        <li><a href="#" class="active">HOME</a></li>
        <li><a href="#">PROJECTS</a></li>
        <li><a href="#">ABOUT</a></li>
        <li><a href="#">CONTACT</a></li>
      </ul>
    </nav>

    <div class="grid-wrap">
      <div class="grid">
        <div class="card"></div>
        <div class="card top-left"><span class="label">Website Design</span></div>
        <div class="card"></div>
        <div class="card"></div>

        <div class="card"></div>
        <div class="card"></div>
        <div class="card middle-left"><span class="label">Graphic Design</span></div>
        <div class="card"></div>

        <div class="card bottom-center"><span class="label">Product Design</span></div>
        <div class="card"></div>
        <div class="card"></div>
        <div class="card middle-center"><span class="label">Film & Photography</span></div>
      </div>

      <div class="circle-shell">
        <div class="circle" id="circle"></div>
      </div>
    </div>

  </div>

  <script>
    const text = "BELLE • DAVIS • ";
    const circle = document.getElementById("circle");

    function renderCircleText() {
      circle.innerHTML = "";
      const size = circle.offsetWidth;
      const radius = size * 0.28;

      [...text].forEach((char, i) => {
        const span = document.createElement("span");

        const angle = (i / text.length) * Math.PI * 2 - Math.PI / 2;
        const x = Math.cos(angle) * radius;
        const y = Math.sin(angle) * radius;
        const rotation = angle * (180 / Math.PI) + 90;

        span.textContent = char === " " ? "\u00A0" : char;
        span.className = "circle-char";

        span.style.transform =
          `translate(calc(-50% + ${x}px), calc(-50% + ${y}px)) rotate(${rotation}deg)`;

        circle.appendChild(span);
      });
    }

    renderCircleText();
    window.addEventListener("resize", renderCircleText);
  </script>

</body>
</html>
